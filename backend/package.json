{
  "name": "collaborative-editor-backend",
  "version": "1.0.0",
  "description": "Real-time collaborative document editor backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore tests/ server.js",
    "test": "jest --coverage --runInBand",
    "test:unit": "jest tests/unit/ --runInBand",
    "test:class": "jest tests/class/ --runInBand",
    "test:integration": "jest tests/integration/ --runInBand",
    "test:load": "artillery run tests/load-test.yml",
    "test:stress": "artillery run tests/stress-test.yml",
    "test:performance": "node tests/run-tests.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "mongodb": "^6.5.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "artillery": "^2.0.31",
    "axios": "^1.16.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "auth/*.js",
      "routes/*.js",
      "utils/*.js",
      "websocket/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 30,
        "functions": 30,
        "lines": 30,
        "statements": 30
      }
    }
  }
}